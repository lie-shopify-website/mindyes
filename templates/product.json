    "custom_liquid_dxgpbQ": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.faq-section {\n  max-width: 1524px;\n  margin: 40px auto 0 auto;\n  padding: 0 30px;\n  border-top: 1px solid #eee;\n}\n.faq-title {\n  font-size: 24px;\n  font-weight: bold;\n  margin-bottom: 25px;\n}\n.faq-item {\n  border-bottom: 1px solid #ddd;\n  margin-bottom: 10px;\n  border-radius: 6px;\n  overflow: hidden;\n}\n.faq-question {\n  cursor: pointer;\n  padding: 15px 10px;\n  font-weight: 600;\n  background: #f7f7f7;\n  position: relative;\n  color: #222;\n  transition: color 0.2s ease;\n}\n.faq-question:hover {\n  color: #000;\n}\n.faq-answer {\n  display: none;\n  padding: 15px;\n  background: #fff;\n  line-height: 1.7;\n  color: #333;\n}\n.faq-question::after {\n  content: \"+\";\n  position: absolute;\n  right: 20px;\n  top: 50%;\n  transform: translateY(-50%);\n  font-size: 18px;\n  font-weight: bold;\n  transition: transform 0.3s ease;\n}\n.faq-question.open::after {\n  content: \"-\";\n}\n</style>\n\n<div class=\"faq-section\">\n  <h2 class=\"title inline-richtext h2\" style=\"margin-bottom: 20px;\">FAQs</h2>\n\n  <div class=\"faq-item\">\n    <div class=\"faq-question\">How long will it take to receive my order?</div>\n    <div class=\"faq-answer\">\n      Delivery time may vary depending on your location, the product size, and the carrier’s schedule. Once your order is shipped, you will receive a tracking number so you can check the latest delivery status.\n    </div>\n  </div>\n\n  <div class=\"faq-item\">\n    <div class=\"faq-question\">What if my package arrives damaged?</div>\n    <div class=\"faq-answer\">\n      <strong>Cause:</strong> The package may have been crushed, dropped, or bumped during shipping.<br><br>\n      Please take clear photos of the damaged box, product, shipping label, and all packaging materials. Contact our customer service team as soon as possible, and we will help you check the issue and provide a proper solution.\n    </div>\n  </div>\n\n  <div class=\"faq-item\">\n    <div class=\"faq-question\">What if parts are missing from my package?</div>\n    <div class=\"faq-answer\">\n      <strong>Cause:</strong> Small accessories or hardware may have shifted inside the package during shipping or unpacking.<br><br>\n      Please check all packaging materials carefully before disposal. If any parts are still missing, contact us with your order number and the missing part details. We will help you resolve the issue as quickly as possible.\n    </div>\n  </div>\n\n  <div class=\"faq-item\">\n    <div class=\"faq-question\">Do I need special tools for assembly?</div>\n    <div class=\"faq-answer\">\n      Many of our resin products are designed for tool-free or simple assembly. If tools are required, the instruction manual will clearly indicate what is needed.\n    </div>\n  </div>\n</div>\n\n<script>\ndocument.querySelectorAll('.faq-question').forEach(function(q) {\n  q.addEventListener('click', function() {\n    this.classList.toggle('open');\n    const answer = this.nextElementSibling;\n    answer.style.display = answer.style.display === 'block' ? 'none' : 'block';\n  });\n});\n</script>",
        "color_scheme": "",
