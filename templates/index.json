    "custom_liquid_myxRzE": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n/* 外层容器，宽度与 Dawn 默认一致 */\n.custom-faq-section {\n  max-width: 1524px; /* 主题默认 page-width */\n  margin: 50px auto;\n  padding: 0 20px; /* 小屏左右留边 */\n}\n\n/* 每个 FAQ 项目 */\n.custom-faq-item {\n  border-bottom: 1px solid #ddd;\n}\n\n/* 问题部分 */\n.custom-faq-question {\n  cursor: pointer;\n  padding: 18px 40px 18px 10px; /* 右边留白 40px 防止箭头和文字重叠 */\n  font-weight: 600;\n  position: relative;\n  color: #333; /* 深灰 */\n  transition: color 0.2s ease;\n}\n\n.custom-faq-question:hover {\n  color: #111; /* 悬停更深一点 */\n}\n\n/* 单箭头图标（更小、更细，贴近 Dawn 默认） */\n.custom-faq-question::after {\n  content: \"\";\n  border: solid currentColor;\n  border-width: 0 1.5px 1.5px 0; /* 更细线条 */\n  display: inline-block;\n  padding: 3px; /* 缩小箭头尺寸 */\n  position: absolute;\n  right: 20px;\n  top: 50%;\n  transform: translateY(-50%) rotate(45deg); /* 默认向下箭头 */\n  transition: transform 0.3s ease;\n}\n\n.custom-faq-question.open::after {\n  transform: translateY(-50%) rotate(-135deg); /* 点击后向上箭头 */\n}\n\n/* 答案部分 */\n.custom-faq-answer {\n  display: none;\n  padding: 0 10px 15px 10px;\n  color: #444; /* 内容颜色比标题浅一点 */\n  line-height: 1.6;\n}\n\n/* 响应式优化 */\n@media (max-width: 768px) {\n  .custom-faq-question {\n    font-size: 16px;\n  }\n}\n</style>\n\n<div class=\"custom-faq-section\">\n  <h2 class=\"title inline-richtext h2\" style=\"margin-bottom: 20px;\"><strong>Frequently Asked Questions</strong></h2>\n\n  <div class=\"custom-faq-item\">\n    <div class=\"custom-faq-question\">How long will it take to receive my sauna?</div>\n    <div class=\"custom-faq-answer\">\n      We process orders in 1–3 business days, and shipping usually takes 5–12 business days. So you’ll have your sauna delivered in about 6–15 business days from your order.\n    </div>\n  </div>\n\n  <div class=\"custom-faq-item\">\n    <div class=\"custom-faq-question\">Is your sauna difficult to assemble?</div>\n    <div class=\"custom-faq-answer\">\n      No. All Outexer saunas are modular in design. You can complete the installation in a short time by following the instructions or watching our video tutorials. Most customers can complete the assembly independently.\n    </div>\n  </div>\n\n  <div class=\"custom-faq-item\">\n    <div class=\"custom-faq-question\">What if my package arrives damaged?</div>\n    <div class=\"custom-faq-answer\">\n      📌 Cause: The package may have been crushed or bumped during shipping.<br><br>\n      💡 Action: Please take clear photos of the entire box, shipping label, and SKU label. Then, record a complete unboxing video (if necessary). If you discover any damaged parts inside the box, we will immediately ship the damaged parts free of charge or arrange compensation.\n    </div>\n  </div>\n\n  <div class=\"custom-faq-item\">\n    <div class=\"custom-faq-question\">Can I return my sauna if I change my mind?</div>\n    <div class=\"custom-faq-answer\">\n      Yes, we offer returns for unused products in original packaging within 30 days of delivery. Contact support to initiate the return.\n    </div>\n  </div>\n\n  <div class=\"custom-faq-item\">\n    <div class=\"custom-faq-question\">Is there a warranty on the sauna?</div>\n    <div class=\"custom-faq-answer\">\n      All Outexer saunas come with a 5-year warranty covering manufacturing defects. Please keep your order confirmation for warranty claims.\n    </div>\n  </div>\n  <div class=\"custom-faq-item\">\n    <div class=\"custom-faq-question\">Are the sauna materials safe and eco-friendly?</div>\n    <div class=\"custom-faq-answer\">\n      Absolutely. We use premium Canadian Hemlock, Red Cedar and Okoume wood, free from harmful chemicals, ensuring a safe and healthy sauna experience.\n    </div>\n  </div>\n</div>\n\n<script>\ndocument.querySelectorAll('.custom-faq-question').forEach(function(question) {\n  question.addEventListener('click', function() {\n    this.classList.toggle('open');\n    const answer = this.nextElementSibling;\n    answer.style.display = answer.style.display === 'block' ? 'none' : 'block';\n  });\n});\n</script>",
        "color_scheme": "",
        "padding_top": 20,
        "padding_bottom": 28
      }
    },
