{% schema %}
{
  "name": "海报轮播",
  "settings": [
    { "type": "select", "id": "carousel_effect", "label": "切换效果",
      "options": [
        { "value": "fade", "label": "淡入淡出" },
        { "value": "slide", "label": "滑动" }
      ],
      "default": "slide"
    },
    { "type": "checkbox", "id": "autoplay", "label": "自动轮播", "default": true },
    { "type": "range", "id": "cycle_speed", "min": 3, "max": 8, "step": 1, "unit": "秒", "label": "轮播间隔", "default": 5 },
    { "type": "checkbox", "id": "show_arrows", "label": "显示箭头", "default": true },
    { "type": "checkbox", "id": "show_pagination", "label": "显示分页器", "default": true },
    { "type": "text", "id": "custom_class", "label": "自定义类名" }
  ],
  "blocks": [
    {
        "type": "slide",
        "name": "幻灯片",
        "settings": [
            { "type": "header","content":"图片"},
            { "type": "image_picker", "id": "slide_image", "label": "图片" },
            { "type": "image_picker", "id": "slide_image_mb", "label": "图片 (手机端)" },
            { "type": "header","content":"视频"},
            { "type": "video", "id": "slide_video", "label": "视频" },
            { "type": "video", "id": "slide_video_mb", "label": "视频 (手机端)" },
            { "type": "paragraph","content":"视频优先播放。上方「图片 / 图片(手机端)」若上传，则分别作为电脑端与手机端视频的 poster；未上传的一端使用对应视频在后台生成的默认封面。"},

            { "type": "checkbox", "id": "desktop_shadow", "label": "电脑端阴影", "default": true },

            { "type": "number", "id": "content_area_width", "label": "内容区域宽度", "default": 530 },
            { "type": "number", "id": "content_area_width_mb", "label": "内容区域宽度 (手机端)", "default": 375 },

            { "type": "header","content":"内容"},
            { "type": "select", "id": "content_position", "options": [
                    { "value": "left_top", "label": "左上" },
                    { "value": "left_center", "label": "左中" },
                    { "value": "left_bottom", "label": "左下" },
                    { "value": "center_top", "label": "中上" },
                    { "value": "center_center", "label": "中间" },
                    { "value": "center_bottom", "label": "中下" },
                    { "value": "right_top", "label": "右上" },
                    { "value": "right_center", "label": "右中" },
                    { "value": "right_bottom", "label": "右下" }
                ],
                "default": "left_center",
                "label": "内容位置"
            },
            { "type": "select", "id": "content_position_mb", "options": [
                    { "value": "left_top", "label": "左上" },
                    { "value": "left_center", "label": "左中" },
                    { "value": "left_bottom", "label": "左下" },
                    { "value": "center_top", "label": "中上" },
                    { "value": "center_center", "label": "中间" },
                    { "value": "center_bottom", "label": "中下" },
                    { "value": "right_top", "label": "右上" },
                    { "value": "right_center", "label": "右中" },
                    { "value": "right_bottom", "label": "右下" }
                ],
                "default": "center_top",
                "label": "内容位置 (手机端)"
            },

            { "type": "select", "id": "content_align", "options": [
                    { "value": "left", "label": "左对齐" },
                    { "value": "center", "label": "中对齐" },
                    { "value": "right", "label": "右对齐" }
                ],
                "default": "left",
                "label": "内容对齐"
            },
            { "type": "select", "id": "content_align_mb", "options": [
                    { "value": "left", "label": "左对齐" },
                    { "value": "center", "label": "中对齐" },
                    { "value": "right", "label": "右对齐" }
                ],
                "default": "center",
                "label": "内容对齐 (手机端)"
            },

            { "type": "checkbox", "id": "show_sale_label", "label": "显示销售标签", "default": true },
            { "type": "text", "id": "sale_label", "label": "销售标签文字", "default": "Hot Selling" },
            { "type": "color", "id": "sale_label_color", "label": "销售标签文字颜色", "default": "#ffffff" },
            { "type": "color", "id": "sale_label_color_mb", "label": "销售标签文字颜色 (手机端)", "default": "#ffffff" },
            { "type": "color", "id": "sale_label_bg", "label": "销售标签背景颜色", "default": "#e56321" },
            { "type": "color", "id": "sale_label_bg_mb", "label": "销售标签背景颜色 (手机端)", "default": "#e56321" },

            { "type": "image_picker", "id": "slide_title_image", "label": "标题图片" },
            { "type": "image_picker", "id": "slide_title_image_mb", "label": "标题图片 (手机端)" },
            { "type": "textarea", "id": "slide_sub_title", "label": "小标题" },
            { "type": "textarea", "id": "slide_title", "label": "大标题" },
            { "type": "select", "id": "slide_title_type", "options": [
                { "value": "p", "label": "p" },
                { "value": "h1", "label": "h1" },
                { "value": "h2", "label": "h2" },
                { "value": "h3", "label": "h3" },
                { "value": "h4", "label": "h4" },
                { "value": "h5", "label": "h5" },
                { "value": "h6", "label": "h6" },
            ],
            "default": "p",
            "label": "大标题标签类型 (SEO优化用)"
            },
            { "type": "number", "id": "slide_title_font_size", "label": "大标题字体大小", "default": 48 },
            { "type": "number", "id": "slide_title_font_size_mb", "label": "大标题字体大小 (手机端)", "default": 36 },

            { "type": "textarea", "id": "slide_info", "label": "内容" },

            { "type": "header","content":"颜色"},
            { "type": "color", "id": "text_color", "label": "文字颜色", "default": "#ffffff", },
            { "type": "color", "id": "text_color_mb", "label": "文字颜色 (手机端)", "default": "#000000" },

            { "type": "header","content":"按钮"},
            { "type": "checkbox", "id": "slide_button_switch", "label": "是否开启按钮", "default": true },
            { "type": "textarea", "id": "slide_button_text", "label": "按钮文字" },
            { "type": "url", "id": "slide_button_url", "label": "按钮链接" },
            { "type": "color", "id": "slide_button_color", "label": "按钮文本颜色", "default": "#000000" },
            { "type": "color", "id": "slide_button_bg", "label": "按钮背景颜色", "default": "#ffffff" },
            { "type": "color", "id": "slide_button_color_mb", "label": "按钮文本颜色 (手机端)", "default": "#ffffff" },
            { "type": "color", "id": "slide_button_bg_mb", "label": "按钮背景颜色 (手机端)", "default": "#000000" }
        ]
    }
  ],
  "presets": [
    {
      "category": "定制模块",
      "name": "海报轮播"
    }
  ]
}
{% endschema %}




{{ 'cm-slideshow.css' | asset_url | stylesheet_tag }}
<div class="cm-slideshow {{ section.settings.custom_class }}" data-section-id="{{ section.id }}">
    <div class="layout-container page-width">
        <div class="swiper-box">
            <div class="swiper main-swiper js-mainSwiper">
                <div class="swiper-wrapper">
                    {% assign index = 0 %} {% comment %} 第一张图片不懒加载 {% endcomment %}
                    {% for block in section.blocks %}
                        <div class="swiper-slide {% if block.settings.desktop_shadow %}desktop-shadow{% endif %}">
                            <div class="slide-image">
                                {% if block.settings.slide_button_url != blank %} 
                                    {% if block.settings.slide_title != blank %}
                                        {% assign slide_title = block.settings.slide_title | strip_html | escape %}
                                    {% else %}
                                    {% assign slide_title = 'skip to next slide' | append: block.settings.slide_button_url | strip_html | escape %}
                                    {% endif %}
                                <a href="{{ block.settings.slide_button_url }}" aria-label="{{ slide_title }}"></a> 
                                {% endif %}
                                
                                {% if block.settings.slide_video != blank and block.settings.slide_video_mb != blank  %}
                                    {% comment %} 视频 {% endcomment %}
                                    {% liquid
                                    assign video_url = block.settings.slide_video.sources[0].url
                                    assign video_mb_url = block.settings.slide_video_mb.sources[0].url

                                    if block.settings.slide_video.sources[1].url != blank
                                        assign video_url = block.settings.slide_video.sources[1].url
                                    endif
                                    if block.settings.slide_video_mb.sources[1].url != blank
                                        assign video_mb_url = block.settings.slide_video_mb.sources[1].url
                                    endif

                                    if block.settings.slide_image != blank
                                        assign poster_desktop = block.settings.slide_image | image_url: width: 1920
                                    elsif block.settings.slide_video.preview_image != blank
                                        assign poster_desktop = block.settings.slide_video.preview_image | image_url: width: 1920
                                    else
                                        assign poster_desktop = ''
                                    endif

                                    if block.settings.slide_image_mb != blank
                                        assign poster_mobile = block.settings.slide_image_mb | image_url: width: 1536
                                    elsif block.settings.slide_video_mb.preview_image != blank
                                        assign poster_mobile = block.settings.slide_video_mb.preview_image | image_url: width: 1536
                                    else
                                        assign poster_mobile = ''
                                    endif
                                    %}
                                    <mf-video 
                                        class="hm-slideshow-video"
                                        autoplay 
                                        muted 
                                        playsinline
                                        webkit-playsinline
                                        loop
                                        preload="metadata"
                                    >
                                        <source src="{{ video_url }}" type="video/mp4" media="(min-width: 1280px)" poster="{{ poster_desktop }}">
                                        <source src="{{ video_url }}" type="video/mp4" media="(min-width: 768px)" poster="{{ poster_desktop }}">
                                        <source src="{{ video_mb_url }}" type="video/mp4" poster="{{ poster_mobile }}">
                                        <div slot="loading"></div>
                                    </mf-video>
                                {% else %}
                                    {% comment %} 图片 {% endcomment %}
                                    {% liquid
                                        assign pc_src = block.settings.slide_image | image_url: width: block.settings.image.width
                                        assign pad_src = block.settings.slide_image | image_url: width: block.settings.image.width
                                        assign m_src = block.settings.slide_image_mb | image_url: width: 1536

                                        if index == 0
                                            assign lazy = false
                                        else
                                            assign lazy = true
                                        endif
                                        assign index = index | plus: 1
                                    %}
                                    
                                    {% render 'resp-img'
                                        pc_src: pc_src,
                                        pad_src: pad_src,
                                        m_src: m_src,
                                        lazy: lazy,
                                        class_name: 'resp-img-class',
                                        alt: block.settings.slide_title
                                    %}
                                {% endif %}
                            </div>

                            <div class="content" data-block-id="{{ section.id }}-{{ block.id }}">
                                <div class="content-inner" data-content-position="{{ block.settings.content_position }}" data-content-position-mb="{{ block.settings.content_position_mb }}">
                                    <div class="content-container">
                                    
                                    {% if block.settings.show_sale_label and block.settings.sale_label != blank %} 
                                        <div class="sale_label slide_block_item"><div class="sale_label-inner">{{ block.settings.sale_label }}</div></div> 
                                    {% endif %}

                                    {% if block.settings.slide_title_image != blank %} 
                                        <div class="slide_title_image slide_block_item">
                                            {% liquid
                                                assign pc_src = block.settings.slide_title_image | image_url: width: block.settings.slide_title_image.width
                                                assign pad_src = block.settings.slide_title_image | image_url: width: block.settings.slide_title_image.width
                                                assign m_src = block.settings.slide_title_image_mb | image_url: width: 767
                                            %}
                                            {% render 'resp-img'
                                                pc_src: pc_src,
                                                pad_src: pad_src,
                                                m_src: m_src,
                                                lazy: true,
                                                class_name: 'resp-img-class',
                                                alt: block.settings.slide_title_image.alt
                                            %}
                                        </div> 
                                    {% endif %}

                                    {% if block.settings.slide_sub_title != blank %} <div class="slide_sub_title slide_block_item">{{ block.settings.slide_sub_title }}</div> {% endif %}
                                    {% if block.settings.slide_title != blank %} <div class="slide_title slide_block_item"><{{ block.settings.slide_title_type }} class="slide_title-inner">{{ block.settings.slide_title }}</{{ block.settings.slide_title_type }}></div> {% endif %}
                                    {% if block.settings.slide_info != blank %} <div class="slide_info slide_block_item">{{ block.settings.slide_info }}</div> {% endif %}

                                    {% if block.settings.slide_button_switch and block.settings.slide_button_text != blank and block.settings.slide_button_url != blank %}
                                        <div class="slide_button slide_block_item">
                                            <a href="{{ block.settings.slide_button_url }}" class="mf-btn"><span>{{ block.settings.slide_button_text }}</span></a>
                                        </div> 
                                    {% endif %}
                                    </div>
                                </div>
                                <style>
                                    [data-block-id="{{ section.id }}-{{ block.id }}"] {
                                        --content-area-width:{{ block.settings.content_area_width }}px;
                                        --content-area-width-mb:{{ block.settings.content_area_width_mb }}px;
                                        --text-color-mb:{{ block.settings.text_color_mb }};
                                        --text-color:{{ block.settings.text_color }};
                                        --slide-button-color:{{ block.settings.slide_button_color }};
                                        --slide-button-bg:{{ block.settings.slide_button_bg }};
                                        --slide-button-color-mb:{{ block.settings.slide_button_color_mb }};
                                        --slide-button-bg-mb:{{ block.settings.slide_button_bg_mb }};
                                        --content-align:{{ block.settings.content_align }};
                                        --content-align-mb:{{ block.settings.content_align_mb }};
                                        --sale-label-color:{{ block.settings.sale_label_color }};
                                        --sale-label-bg:{{ block.settings.sale_label_bg }};
                                        --sale-label-color-mb:{{ block.settings.sale_label_color_mb }};
                                        --sale-label-bg-mb:{{ block.settings.sale_label_bg_mb }};
                                        --slide-title-font-size:{{ block.settings.slide_title_font_size }}px;
                                        --slide-title-font-size-mb:{{ block.settings.slide_title_font_size_mb }}px;
                                    }
                                </style>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {% if section.blocks.size > 1 and section.settings.show_pagination %}
                <div class="swiper-pagination"></div>
                {% endif %}

                {% if section.blocks.size > 1 and section.settings.show_arrows %}
                <div class="swiper-buttons mobile-hidden">
                    <button
                      class="swiper-button-prev"
                      type="button"
                      aria-label="Previous slide"
                    >
                        <svg width="11" height="19" viewBox="0 0 11 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9.83333 17.7272L1.5 9.39388L9.83333 1.06055" stroke="black" stroke-width="3" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <button
                      class="swiper-button-next"
                      type="button" 
                      aria-label="Next slide" 
                    >
                        <svg width="11" height="19" viewBox="0 0 11 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M1.06022 1.06087L9.39356 9.39421L1.06022 17.7275" stroke="black" stroke-width="3" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
    ;(function() {
        const oSection = document.querySelector('[data-section-id="{{ section.id }}"]');

        {% comment %} 轮播 {% endcomment %}
        function initSwiper() {
            new Swiper(oSection.querySelector('.main-swiper'), {
                loop: {% if section.blocks.size > 1 %} true {% else %} false {% endif %},
                {% if section.settings.autoplay and section.blocks.size > 1 %}
                    autoplay: {
                        delay: {{ section.settings.cycle_speed | times: 1000 }},
                        disableOnInteraction: false,
                    },
                {% endif %}
                {% if section.settings.show_arrows %}
                    navigation: {
                        nextEl: oSection.querySelector('.swiper-button-next'),
                        prevEl: oSection.querySelector('.swiper-button-prev'),
                    },
                {% endif %}
                {% if section.settings.show_pagination %}
                    pagination: {
                        el: oSection.querySelector('.swiper-pagination'),
                        clickable: true,
                    },
                {% endif %}
            });
        }
        window.addEventListener('DOMContentLoaded', () => {
            initSwiper();
        });

    })();
</script>