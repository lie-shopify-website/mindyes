{% schema %}
{
  "name": "链接图文卡片",
  "settings": [
    { "type": "textarea", "id": "section_title", "label": "版块标题", "default":"Shop Top Sellers"},
    { "type": "header","content":"颜色"},
    { "type": "color", "id": "bg_color", "label": "背景颜色", "default": "transparent" },
    { "type": "color", "id": "bg_color_mb", "label": "背景颜色 (手机端)", "default": "transparent" },
    { "type": "checkbox", "id": "remove_top_padding", "label": "移除上边距", "default": false },
    { "type": "checkbox", "id": "remove_bottom_padding", "label": "移除下边距", "default": false },
    { "type": "text", "id": "custom_class", "label": "自定义类名" }
  ],
  "presets": [
    {
      "category": "定制模块",
      "name": "链接图文卡片"
    }
  ]
}
{% endschema %}

{% liquid
  assign image_width = 800
  assign flag = true
  assign curr_collection = section.settings.collection
  if curr_collection.size < 1
    assign flag = false
  endif
%}

<style>
    [data-section-id="{{ section.id }}"] {
        --bg-color: {{ section.settings.bg_color }}; 
        --bg-color-mb: {{ section.settings.bg_color_mb }};
    }
</style>
{{ 'cm-featured-products.css' | asset_url | stylesheet_tag }}
<div class="cm-featured-products {% if section.settings.remove_top_padding %}remove-top-padding{% endif %} {% if section.settings.remove_bottom_padding %}remove-bottom-padding{% endif %} {{ section.settings.custom_class }}" data-section-id="{{ section.id }}">
    <div class="layout-container page-width">
        {% if section.settings.section_title != blank %}
            <div class="section-heading">
                <h3 class="heading-title">{{ section.settings.section_title }}</h3>
                {% if section.settings.section_see_more != blank and curr_collection != blank %}
                    <a href="{{ curr_collection.url }}">{{ section.settings.section_see_more }} ></a>
                {% endif %}
            </div>
        {% endif %}

        {% if flag %}
        <div class="swiper-box">
            <div class="swiper main-swiper js-mainSwiper">
                <div class="swiper-wrapper">
                    {% for curr_product in curr_collection.products limit: section.settings.limit_products %}
                        <div class="swiper-slide">
                            <div class="slide-image">
                                
                                
                                {% comment %} 图片 {% endcomment %}
                                {% liquid
                                    assign pc_src = curr_product.featured_image | image_url: width: image_width
                                    assign pad_src = curr_product.featured_image | image_url: width: image_width
                                    assign m_src = curr_product.featured_image | image_url: width: image_width
                                %}
                                
                                {% render 'resp-img'
                                    pc_src: pc_src,
                                    pad_src: pad_src,
                                    m_src: m_src,
                                    class_name: 'resp-img-class',
                                    alt: curr_product.title
                                %}
                            </div>

                            <div class="content">
                                <div class="content-inner">
                                    <div class="product-title">
                                        <a href="{{ curr_product.url }}">{{ curr_product.title }}</a>
                                    </div>
                                    <div class="product-price">
                                        {% render 'price', product: curr_product, price_class: '', show_compare_at_price: true %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>

<script>
    ;(function() {
        const oSection = document.querySelector('[data-section-id="{{ section.id }}"]');

        {% comment %}
          手机：Swiper 横向约 2.05 张；电脑：销毁 Swiper，用 CSS Grid 四列铺开（任意数量自动换行，无轮播）。
        {% endcomment %}
        let cmCollectionGridSwiper = null;
        const CM_CG_DESKTOP = window.matchMedia('(min-width: 990px)');

        function syncCmCollectionGridCarousel() {
            if (!oSection) return;
            const el = oSection.querySelector('.main-swiper');
            if (!el || el.querySelectorAll('.swiper-slide').length === 0) return;

            if (CM_CG_DESKTOP.matches) {
                if (cmCollectionGridSwiper) {
                    cmCollectionGridSwiper.destroy(true, true);
                    cmCollectionGridSwiper = null;
                }
                el.classList.add('cm-desktop-grid');
                return;
            }

            el.classList.remove('cm-desktop-grid');
            if (cmCollectionGridSwiper) {
                cmCollectionGridSwiper.update();
                return;
            }

            cmCollectionGridSwiper = new Swiper(el, {
                watchOverflow: true,
                observer: true,
                observeParents: true,
                speed: 400,
                spaceBetween: 16,
                slidesPerView: 2.05,
                slidesPerGroup: 1,
                grid: {
                    rows: 2,
                    fill: 'row'
                },
            });
        }

        let cmCollectionGridResizeTimer;
        function onCmCollectionGridResize() {
            clearTimeout(cmCollectionGridResizeTimer);
            cmCollectionGridResizeTimer = setTimeout(syncCmCollectionGridCarousel, 120);
        }

        if (typeof CM_CG_DESKTOP.addEventListener === 'function') {
            CM_CG_DESKTOP.addEventListener('change', syncCmCollectionGridCarousel);
        } else if (typeof CM_CG_DESKTOP.addListener === 'function') {
            CM_CG_DESKTOP.addListener(syncCmCollectionGridCarousel);
        }
        window.addEventListener('resize', onCmCollectionGridResize);

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', syncCmCollectionGridCarousel);
        } else {
            syncCmCollectionGridCarousel();
        }

    })();
</script>