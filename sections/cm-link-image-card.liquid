{% schema %}
{
  "name": "链接图文卡片",
  "settings": [
    { "type": "textarea", "id": "section_title", "label": "版块标题", "default":"Shop Top Sellers"},
    { "type": "header","content":"颜色"},
    { "type": "color", "id": "bg_color", "label": "背景颜色", "default": "transparent" },
    { "type": "color", "id": "bg_color_mb", "label": "背景颜色 (手机端)", "default": "transparent" },
    { "type": "checkbox", "id": "remove_top_padding", "label": "移除上边距", "default": false },
    { "type": "checkbox", "id": "remove_bottom_padding", "label": "移除下边距", "default": false },
    { "type": "text", "id": "custom_class", "label": "自定义类名" }
  ],
  "blocks": [
    {
        "type": "item",
        "name": "item",
        "settings": [
            { "type": "header","content":"图片"},
            { "type": "image_picker", "id": "item_image", "label": "图片" },
            { "type": "image_picker", "id": "item_image_mb", "label": "图片 (手机端)" },

            { "type": "header","content":"内容"},
            { "type": "select", "id": "content_position", "label": "内容位置", "options": [
                { "value": "top_inside", "label": "顶部内嵌" },
                { "value": "top_outside", "label": "顶部外嵌" },
                { "value": "bottom_inside", "label": "底部内嵌" },
                { "value": "bottom_outside", "label": "底部外嵌" },
            ], "default": "bottom_outside", "info":"内容内嵌表示内容浮在图片上面, 内容外嵌表示内容与图片平级显示"},

            { "type": "select", "id": "content_position_mb", "label": "内容位置 (手机端)", "options": [
                { "value": "top_inside", "label": "顶部内嵌" },
                { "value": "top_outside", "label": "顶部外嵌" },
                { "value": "bottom_inside", "label": "底部内嵌" },
                { "value": "bottom_outside", "label": "底部外嵌" },
            ], "default": "bottom_inside", "info":"内容内嵌表示内容浮在图片上面, 内容外嵌表示内容与图片平级显示"},

            { "type": "textarea", "id": "item_title", "label": "标题" },
            { "type": "textarea", "id": "item_desc", "label": "描述" },

            { "type": "header","content":"颜色"},
            { "type": "color", "id": "text_color", "label": "文字颜色", "default": "#ffffff", },
            { "type": "color", "id": "text_color_mb", "label": "文字颜色 (手机端)", "default": "#000000" },

            { "type": "header","content":"链接"},
            { "type": "url", "id": "item_link", "label": "链接" }
        ]
    }
  ],
  "presets": [
    {
      "category": "定制模块",
      "name": "链接图文卡片"
    }
  ]
}
{% endschema %}

<style>
    [data-section-id="{{ section.id }}"] {
        --bg-color: {{ section.settings.bg_color }}; 
        --bg-color-mb: {{ section.settings.bg_color_mb }};
    }
</style>
{{ 'cm-link-image-card.css' | asset_url | stylesheet_tag }}
<div class="cm-link-image-card section-spacing {% if section.settings.remove_top_padding %}remove-top-padding{% endif %} {% if section.settings.remove_bottom_padding %}remove-bottom-padding{% endif %} {{ section.settings.custom_class }}" data-section-id="{{ section.id }}">
    <div class="layout-container page-width">
        {% if section.settings.section_title != blank %}
            <div class="section-heading">
                <h3 class="heading-title">{{ section.settings.section_title }}</h3>
            </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
        <div class="swiper-box">
            <div class="swiper main-swiper js-mainSwiper">
                <div class="swiper-wrapper">
                    {% for block in section.blocks %}
                        <div class="swiper-slide" data-content-position="{{ block.settings.content_position }}" data-content-position-mb="{{ block.settings.content_position_mb }}">
                            {% if block.settings.item_link != blank %}
                                <a href="{{ block.settings.item_link }}" class="slide-link" aria-label="{{ block.settings.item_title }}"></a>
                            {% endif %}

                            <div class="slide-image">
                                {% comment %} 图片 {% endcomment %}
                                {% liquid
                                    assign pc_src = block.settings.item_image | image_url: width: block.settings.item_image.width
                                    assign pad_src = block.settings.item_image | image_url: width: block.settings.item_image.width
                                    assign m_src = block.settings.item_image_mb | image_url: width: block.settings.item_image_mb.width
                                %}
                                {% render 'resp-img'
                                    pc_src: pc_src,
                                    pad_src: pad_src,
                                    m_src: m_src,
                                    class_name: 'resp-img-class',
                                    alt: block.settings.item_title
                                %}
                            </div>

                            <div class="content" data-block-id="{{ section.id }}-{{ block.id }}">
                                <div class="content-inner">
                                    {% if block.settings.item_title != blank %}<div class="title"> <p>{{ block.settings.item_title }}</p> </div>{% endif %}
                                    {% if block.settings.item_title != blank %}<div class="desc"> <p>{{ block.settings.item_desc }}</p> </div>{% endif %}
                                </div>
                            </div>

                            <style>
                                [data-block-id="{{ section.id }}-{{ block.id }}"] {
                                    --text-color: {{ block.settings.text_color }};
                                    --text-color-mb: {{ block.settings.text_color_mb }};
                                }
                            </style>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>

<script>
    ;(function() {
        const oSection = document.querySelector('[data-section-id="{{ section.id }}"]');

        {% comment %}
          手机：Swiper 横向约 1.4 张；电脑：销毁 Swiper，用 CSS Grid 四列铺开（任意数量自动换行，无轮播）。
        {% endcomment %}
        let cmCollectionGridSwiper = null;
        const CM_CG_DESKTOP = window.matchMedia('(min-width: 990px)');

        function syncCmCollectionGridCarousel() {
            if (!oSection) return;
            const el = oSection.querySelector('.main-swiper');
            if (!el || el.querySelectorAll('.swiper-slide').length === 0) return;

            if (CM_CG_DESKTOP.matches) {
                if (cmCollectionGridSwiper) {
                    cmCollectionGridSwiper.destroy(true, true);
                    cmCollectionGridSwiper = null;
                }
                el.classList.add('cm-desktop-grid');
                return;
            }

            el.classList.remove('cm-desktop-grid');
            if (cmCollectionGridSwiper) {
                cmCollectionGridSwiper.update();
                return;
            }

            cmCollectionGridSwiper = new Swiper(el, {
                watchOverflow: true,
                observer: true,
                observeParents: true,
                speed: 400,
                spaceBetween: 16,
                slidesPerView: 1.4,
                slidesPerGroup: 1,
            });
        }

        let cmCollectionGridResizeTimer;
        function onCmCollectionGridResize() {
            clearTimeout(cmCollectionGridResizeTimer);
            cmCollectionGridResizeTimer = setTimeout(syncCmCollectionGridCarousel, 120);
        }

        if (typeof CM_CG_DESKTOP.addEventListener === 'function') {
            CM_CG_DESKTOP.addEventListener('change', syncCmCollectionGridCarousel);
        } else if (typeof CM_CG_DESKTOP.addListener === 'function') {
            CM_CG_DESKTOP.addListener(syncCmCollectionGridCarousel);
        }
        window.addEventListener('resize', onCmCollectionGridResize);

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', syncCmCollectionGridCarousel);
        } else {
            syncCmCollectionGridCarousel();
        }

    })();
</script>