{% schema %}
{
  "name": "分类系列网格",
  "settings": [
    { "type": "header","content":"颜色"},
    { "type": "color", "id": "bg_color", "label": "背景颜色", "default": "#ffffff" },
    { "type": "color", "id": "bg_color_mb", "label": "背景颜色 (手机端)", "default": "#fcf9f1" },
    { "type": "checkbox", "id": "remove_top_padding", "label": "移除上边距", "default": false },
    { "type": "checkbox", "id": "remove_bottom_padding", "label": "移除下边距", "default": false },
    { "type": "text", "id": "custom_class", "label": "自定义类名" }
  ],
  "blocks": [
    {
        "type": "collection",
        "name": "系列",
        "settings": [
            { "type": "collection", "id": "collection", "label": "系列" },
            { "type": "header","content":"图片"},
            { "type": "image_picker", "id": "collection_image", "label": "系列图片" },
            { "type": "image_picker", "id": "collection_image_mb", "label": "系列图片 (手机端)" },

            { "type": "header","content":"内容"},
            { "type": "select", "id": "content_position", "options": [
                    { "value": "left_top", "label": "左上" },
                    { "value": "left_center", "label": "左中" },
                    { "value": "left_bottom", "label": "左下" },
                    { "value": "center_top", "label": "中上" },
                    { "value": "center_center", "label": "中间" },
                    { "value": "center_bottom", "label": "中下" },
                    { "value": "right_top", "label": "右上" },
                    { "value": "right_center", "label": "右中" },
                    { "value": "right_bottom", "label": "右下" }
                ],
                "default": "left_center",
                "label": "内容位置"
            },
            { "type": "select", "id": "content_position_mb", "options": [
                    { "value": "left_top", "label": "左上" },
                    { "value": "left_center", "label": "左中" },
                    { "value": "left_bottom", "label": "左下" },
                    { "value": "center_top", "label": "中上" },
                    { "value": "center_center", "label": "中间" },
                    { "value": "center_bottom", "label": "中下" },
                    { "value": "right_top", "label": "右上" },
                    { "value": "right_center", "label": "右中" },
                    { "value": "right_bottom", "label": "右下" }
                ],
                "default": "center_top",
                "label": "内容位置 (手机端)"
            },

            { "type": "select", "id": "content_align", "options": [
                    { "value": "left", "label": "左对齐" },
                    { "value": "center", "label": "中对齐" },
                    { "value": "right", "label": "右对齐" }
                ],
                "default": "left",
                "label": "内容对齐"
            },
            { "type": "select", "id": "content_align_mb", "options": [
                    { "value": "left", "label": "左对齐" },
                    { "value": "center", "label": "中对齐" },
                    { "value": "right", "label": "右对齐" }
                ],
                "default": "center",
                "label": "内容对齐 (手机端)"
            },
            
            { "type": "textarea", "id": "collection_title", "label": "系列标题", "info":"若不填写，则使用系列本身标题" },

            { "type": "header","content":"颜色"},
            { "type": "color", "id": "text_color", "label": "文字颜色", "default": "#ffffff", },
            { "type": "color", "id": "text_color_mb", "label": "文字颜色 (手机端)", "default": "#000000" },

            { "type": "header","content":"按钮"},
            { "type": "checkbox", "id": "collection_button_switch", "label": "是否开启按钮", "default": true },
            { "type": "textarea", "id": "collection_button_text", "label": "按钮文字" },
            { "type": "color", "id": "collection_button_color", "label": "按钮文本颜色", "default": "#ffffff" },
            { "type": "color", "id": "collection_button_bg", "label": "按钮背景颜色", "default": "#f05a42" },
            { "type": "color", "id": "collection_button_color_mb", "label": "按钮文本颜色 (手机端)", "default": "#ffffff" },
            { "type": "color", "id": "collection_button_bg_mb", "label": "按钮背景颜色 (手机端)", "default": "#f05a42" }
        ]
    }
  ],
  "presets": [
    {
      "category": "定制模块",
      "name": "分类系列网格"
    }
  ]
}
{% endschema %}



<style>
    [data-section-id="{{ section.id }}"] {
        --bg-color: {{ section.settings.bg_color }}; 
        --bg-color-mb: {{ section.settings.bg_color_mb }};
    }
</style>
{{ 'cm-collection-grid.css' | asset_url | stylesheet_tag }}
<div class="cm-collection-grid {% if section.settings.remove_top_padding %}remove-top-padding{% endif %} {% if section.settings.remove_bottom_padding %}remove-bottom-padding{% endif %} {{ section.settings.custom_class }}" data-section-id="{{ section.id }}">
    <div class="layout-container page-width">
        <div class="swiper-box">
            <div class="swiper main-swiper js-mainSwiper">
                <div class="swiper-wrapper">
                    {% for block in section.blocks %}
                        <div class="swiper-slide">
                            <div class="slide-image">
                                
                                
                                {% comment %} 图片 {% endcomment %}
                                {% liquid
                                    assign pc_src = block.settings.collection_image | image_url: width: block.settings.collection_image.width
                                    assign pad_src = block.settings.collection_image | image_url: width: block.settings.collection_image.width
                                    assign m_src = block.settings.collection_image_mb | image_url: width: block.settings.collection_image_mb.width
                                    assign collection_title = block.settings.collection_title | default: block.settings.collection.title
                                %}
                                
                                {% render 'resp-img'
                                    pc_src: pc_src,
                                    pad_src: pad_src,
                                    m_src: m_src,
                                    class_name: 'resp-img-class',
                                    alt: collection_title
                                %}
                            </div>

                            <div class="content" data-block-id="{{ section.id }}-{{ block.id }}">
                                <div class="content-inner" data-content-position="{{ block.settings.content_position }}" data-content-position-mb="{{ block.settings.content_position_mb }}">
                                    <div class="content-container">
                                    {% if collection_title != blank %} <div class="collection_title collection-block-item"><div class="collection_title-inner">{{ collection_title }}</div></div> {% endif %}

                                    {% if block.settings.collection_button_switch and block.settings.collection_button_text != blank %}
                                        <div class="collection_link collection-block-item">
                                            <a href="{{ block.settings.collection.url }}" class="mf-btn">{{ block.settings.collection_button_text }}</a>
                                        </div>
                                    {% endif %}
                                    </div>
                                </div>
                                <style>
                                    [data-block-id="{{ section.id }}-{{ block.id }}"] {
                                        --text-color-mb:{{ block.settings.text_color_mb }};
                                        --text-color:{{ block.settings.text_color }};
                                        --content-align:{{ block.settings.content_align }};
                                        --content-align-mb:{{ block.settings.content_align_mb }};
                                        --collection-button-color:{{ block.settings.collection_button_color }};
                                        --collection-button-bg:{{ block.settings.collection_button_bg }};
                                        --collection-button-color-mb:{{ block.settings.collection_button_color_mb }};
                                        --collection-button-bg-mb:{{ block.settings.collection_button_bg_mb }};
                                    }
                                </style>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    ;(function() {
        const oSection = document.querySelector('[data-section-id="{{ section.id }}"]');

        {% comment %}
          手机：Swiper 横向约 1.3 张；电脑：销毁 Swiper，用 CSS Grid 三列铺开（任意数量自动换行，无轮播）。
        {% endcomment %}
        let cmCollectionGridSwiper = null;
        const CM_CG_DESKTOP = window.matchMedia('(min-width: 990px)');

        function syncCmCollectionGridCarousel() {
            if (!oSection) return;
            const el = oSection.querySelector('.main-swiper');
            if (!el || el.querySelectorAll('.swiper-slide').length === 0) return;

            if (CM_CG_DESKTOP.matches) {
                if (cmCollectionGridSwiper) {
                    cmCollectionGridSwiper.destroy(true, true);
                    cmCollectionGridSwiper = null;
                }
                el.classList.add('cm-desktop-grid');
                return;
            }

            el.classList.remove('cm-desktop-grid');
            if (cmCollectionGridSwiper) {
                cmCollectionGridSwiper.update();
                return;
            }

            cmCollectionGridSwiper = new Swiper(el, {
                watchOverflow: true,
                observer: true,
                observeParents: true,
                speed: 400,
                spaceBetween: 16,
                slidesPerView: 1.3,
                slidesPerGroup: 1,
            });
        }

        let cmCollectionGridResizeTimer;
        function onCmCollectionGridResize() {
            clearTimeout(cmCollectionGridResizeTimer);
            cmCollectionGridResizeTimer = setTimeout(syncCmCollectionGridCarousel, 120);
        }

        if (typeof CM_CG_DESKTOP.addEventListener === 'function') {
            CM_CG_DESKTOP.addEventListener('change', syncCmCollectionGridCarousel);
        } else if (typeof CM_CG_DESKTOP.addListener === 'function') {
            CM_CG_DESKTOP.addListener(syncCmCollectionGridCarousel);
        }
        window.addEventListener('resize', onCmCollectionGridResize);

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', syncCmCollectionGridCarousel);
        } else {
            syncCmCollectionGridCarousel();
        }

    })();
</script>